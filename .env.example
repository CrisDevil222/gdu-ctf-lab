# =============================================================
# GDU-CTF - Environment Variables
# Copy file này thành .env và điền flag thật vào
# File .env KHÔNG được commit lên GitHub!
# =============================================================

# ── WEB CHALLENGES ─────────────────────────────────────────
FLAG_WEB_SQLI_EASY=GDUCTF{your_flag_here}
FLAG_WEB_XSS_EASY=GDUCTF{your_flag_here}
FLAG_WEB_IDOR_MEDIUM=GDUCTF{your_flag_here}
FLAG_WEB_SSTI_HARD=GDUCTF{your_flag_here}
FLAG_WEB_PATH_TRAVERSAL=GDUCTF{your_flag_here}
FLAG_WEB_SQLI_MEDIUM=GDUCTF{your_flag_here}
FLAG_WEB_SSRF_MEDIUM=GDUCTF{your_flag_here}

# ── CRYPTO CHALLENGES ──────────────────────────────────────
FLAG_CRYPTO_CAESAR=GDUCTF{your_flag_here}

# ── FORENSICS CHALLENGES ───────────────────────────────────
FLAG_FORENSICS_STEGO=GDUCTF{your_flag_here}
FLAG_FORENSICS_DISK_PARTITION=GDUCTF{your_flag_here}
FLAG_FORENSICS_FILE_HIDDEN=GDUCTF{your_flag_here}
FLAG_FORENSICS_TLS=GDUCTF{your_flag_here}
FLAG_FORENSICS_TRASHBIN=GDUCTF{your_flag_here}

# ── RE CHALLENGES ──────────────────────────────────────────
FLAG_RE_STRINGS=GDUCTF{your_flag_here}
FLAG_RE_XOR=GDUCTF{your_flag_here}

# ── PWN CHALLENGES ─────────────────────────────────────────
FLAG_PWN_BOF=GDUCTF{your_flag_here}
FLAG_PWN_RET2WIN=GDUCTF{your_flag_here}

# ── MISC CHALLENGES ────────────────────────────────────────
FLAG_MISC_MORSE=GDUCTF{your_flag_here}

# ── OSINT CHALLENGES ───────────────────────────────────────
FLAG_OSINT_METADATA=GDUCTF{your_flag_here}

# ── GOOGLE DRIVE LINKS (Forensics file downloads) ──────────
DISK_IMG_LINK=https://drive.google.com/your_link_here
WAV_LINK=https://drive.google.com/your_link_here
TLS_PCAP_LINK=https://drive.google.com/your_link_here
TLS_KEYLOG_LINK=https://drive.google.com/your_link_here
TRASHBIN_PCAP_LINK=https://drive.google.com/your_link_here
